rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Shared UAT Firestore rules for:
    // - hockey-2026 squad tracker
    // - mentone-fixture public fixture app
    //
    // Firestore rules are project-wide. Keep this file in sync with the
    // mentone-fixture repo before deploying rules to hockey-2026-uat.

    // Mentone Fixture app collections: public read, server/admin writes only.
    match /teams/{teamId}          { allow read: if true; allow write: if false; }
    match /fixtures/{fixtureId}    { allow read: if true; allow write: if false; }
    match /competitions/{compId}   { allow read: if true; allow write: if false; }
    match /ladders/{teamId}        { allow read: if true; allow write: if false; }
    match /clubOverrides/{rawName} { allow read: if true; allow write: if false; }
    match /syncState/{compId}      { allow read: if true; allow write: if false; }

    // Squad tracker collections: keep existing UAT behavior until auth rules
    // are reintroduced deliberately.
    match /config/{docId} {
      allow read, write: if true;
    }
    match /players/{playerId} {
      allow read, write: if true;
    }
    match /rounds/{roundId} {
      allow read, write: if true;
    }
    match /rounds/{roundId}/{document=**} {
      allow read, write: if true;
    }
    match /playerUnavailability/{docId} {
      allow read, write: if true;
    }
    match /votes/{voteId} {
      allow read, write: if true;
    }
    match /votes/{voteId}/{document=**} {
      allow read, write: if true;
    }
    match /hvSync/{docId} {
      allow read, write: if true;
    }
    match /weeklyDigests/{docId} {
      allow read, write: if true;
    }
  }
}
