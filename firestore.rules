rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Open read/write — auth gate parked, revisit when magic link flow is fixed
    // TODO: re-enable auth requirement: allow read, write: if request.auth != null;
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
